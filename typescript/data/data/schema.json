{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aladac/dubs/data/schema.json",
  "title": "Dubs Theme",
  "description": "Theme definition for the dubs name generator",
  "type": "object",
  "required": ["name", "display_name", "categories", "default_category"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Machine-readable theme identifier (lowercase, hyphens allowed)"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable theme name"
    },
    "categories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      },
      "description": "Named lists of nouns. Keys are category names, values are arrays of slugified nouns."
    },
    "default_category": {
      "type": "string",
      "description": "Must reference an existing key in categories"
    }
  }
}
